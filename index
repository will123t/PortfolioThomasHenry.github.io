<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MON SITE — Portefolio </title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --rouge:     #cc0000;
      --rouge-vif: #ff0000;
      --rouge-glow:#ff000044;
      --noir:      #0a0a0a;
      --noir-2:    #111111;
      --noir-3:    #1a1a1a;
      --gris:      #2a2a2a;
      --gris-clair:#888888;
      --blanc:     #f0f0f0;
      --metal:     #c0c0c0;
    }

    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--noir);
      color: var(--blanc);
      font-family: 'Rajdhani', sans-serif;
      overflow-x: hidden;
      cursor: crosshair;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        repeating-linear-gradient(0deg,   transparent, transparent 39px, #cc000010 40px),
        repeating-linear-gradient(90deg,  transparent, transparent 39px, #cc000010 40px);
      pointer-events: none;
      z-index: 0;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 3rem;
      height: 64px;
      background: rgba(10,10,10,0.95);
      border-bottom: 1px solid var(--rouge);
      backdrop-filter: blur(8px);
    }
    .nav-logo {
      font-family: 'Orbitron', monospace;
      font-weight: 900;
      font-size: 1.4rem;
      color: var(--rouge-vif);
      letter-spacing: 4px;
      text-shadow: 0 0 16px var(--rouge-vif);
      text-decoration: none;
    }
    .nav-logo span { color: var(--blanc); }
    nav ul { list-style: none; display: flex; gap: 2.5rem; }
    nav ul a {
      font-family: 'Rajdhani', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gris-clair);
      text-decoration: none;
      position: relative;
      transition: color 0.2s;
    }
    nav ul a::after {
      content: '';
      position: absolute;
      bottom: -4px; left: 0;
      width: 0; height: 1px;
      background: var(--rouge-vif);
      transition: width 0.3s;
      box-shadow: 0 0 6px var(--rouge-vif);
    }
    nav ul a:hover { color: var(--blanc); }
    nav ul a:hover::after { width: 100%; }

    /* HERO */
    #hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 0 8rem;
      overflow: hidden;
    }
    #hero::after {
      content: '';
      position: absolute;
      top: 0; right: 0;
      width: 42%;
      height: 100%;
      background: linear-gradient(135deg, transparent 40%, #1a0000 100%);
      border-left: 2px solid var(--rouge);
      clip-path: polygon(8% 0, 100% 0, 100% 100%, 0 100%);
    }
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 640px;
    }
    .hero-tag {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.8rem;
      color: var(--rouge-vif);
      letter-spacing: 4px;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .hero-tag::before {
      content: '';
      display: inline-block;
      width: 24px; height: 2px;
      background: var(--rouge-vif);
      box-shadow: 0 0 6px var(--rouge-vif);
    }
    h1 {
      font-family: 'Orbitron', monospace;
      font-size: clamp(2.8rem, 6vw, 5rem);
      font-weight: 900;
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: -1px;
      margin-bottom: 0.4rem;
    }
    h1 .accent {
      color: var(--rouge-vif);
      text-shadow: 0 0 30px var(--rouge-vif), 0 0 60px var(--rouge-glow);
    }
    .hero-sub {
      font-family: 'Share Tech Mono', monospace;
      font-size: 1rem;
      color: var(--gris-clair);
      margin: 1.5rem 0 2.5rem;
      line-height: 1.7;
      border-left: 2px solid var(--rouge);
      padding-left: 1rem;
    }
    .btn-group { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn {
      font-family: 'Orbitron', monospace;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      padding: 0.9rem 2rem;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.25s;
      clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 0 100%);
    }
    .btn-primary {
      background: var(--rouge);
      color: var(--blanc);
      box-shadow: 0 0 20px var(--rouge-glow);
    }
    .btn-primary:hover {
      background: var(--rouge-vif);
      box-shadow: 0 0 40px var(--rouge-vif), 0 0 80px var(--rouge-glow);
      transform: translateY(-2px);
    }
    .btn-outline {
      background: transparent;
      color: var(--blanc);
      border: 1px solid var(--rouge);
    }
    .btn-outline:hover {
      background: rgba(204,0,0,0.15);
      box-shadow: 0 0 20px var(--rouge-glow);
      transform: translateY(-2px);
    }
    .hero-deco {
      position: absolute;
      right: 4%;
      top: 50%;
      transform: translateY(-50%);
      z-index: 3;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      opacity: 0.7;
    }
    .deco-line {
      width: 2px;
      height: 80px;
      background: linear-gradient(to bottom, transparent, var(--rouge), transparent);
    }
    .deco-diamond {
      width: 12px; height: 12px;
      background: var(--rouge-vif);
      transform: rotate(45deg);
      box-shadow: 0 0 16px var(--rouge-vif);
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; box-shadow: 0 0 16px var(--rouge-vif); }
      50%       { opacity: 0.5; box-shadow: 0 0 4px var(--rouge-vif); }
    }

    /* STATS */
    .stats-bar {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid var(--gris);
      border-bottom: 1px solid var(--gris);
      background: rgba(17,17,17,0.9);
    }
    .stat {
      padding: 2rem;
      text-align: center;
      border-right: 1px solid var(--gris);
      transition: background 0.3s;
    }
    .stat:last-child { border-right: none; }
    .stat:hover { background: rgba(204,0,0,0.06); }
    .stat-num {
      font-family: 'Orbitron', monospace;
      font-size: 2.2rem;
      font-weight: 900;
      color: var(--rouge-vif);
      text-shadow: 0 0 20px var(--rouge-glow);
    }
    .stat-label {
      font-size: 0.75rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--gris-clair);
      margin-top: 0.3rem;
    }

    /* SECTIONS */
    section {
      position: relative;
      z-index: 1;
      padding: 6rem 8rem;
    }
    .section-title {
      font-family: 'Orbitron', monospace;
      font-size: 0.7rem;
      letter-spacing: 5px;
      color: var(--rouge-vif);
      text-transform: uppercase;
      margin-bottom: 0.6rem;
    }
    h2 {
      font-family: 'Orbitron', monospace;
      font-size: clamp(1.6rem, 3.5vw, 2.6rem);
      font-weight: 900;
      text-transform: uppercase;
      margin-bottom: 3rem;
      position: relative;
      display: inline-block;
    }
    h2::after {
      content: '';
      position: absolute;
      bottom: -8px; left: 0;
      width: 60px; height: 2px;
      background: var(--rouge-vif);
      box-shadow: 0 0 8px var(--rouge-vif);
    }

    /* PROJETS */
    #projets { background: var(--noir-2); }
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5px;
    }
    .card {
      background: var(--noir-3);
      padding: 2rem;
      border: 1px solid var(--gris);
      position: relative;
      overflow: hidden;
      transition: all 0.3s;
      clip-path: polygon(0 0, calc(100% - 18px) 0, 100% 18px, 100% 100%, 18px 100%, 0 calc(100% - 18px));
    }
    .card::before {
      content: '';
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(204,0,0,0.05), transparent);
      transition: left 0.5s;
    }
    .card:hover::before { left: 100%; }
    .card:hover {
      border-color: var(--rouge);
      box-shadow: 0 0 20px rgba(204,0,0,0.2), inset 0 0 20px rgba(204,0,0,0.05);
      transform: translateY(-4px);
    }
    .card-tag {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.7rem;
      color: var(--rouge-vif);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 0.8rem;
    }
    .card h3 {
      font-family: 'Orbitron', monospace;
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.8rem;
    }
    .card p { font-size: 0.9rem; color: var(--gris-clair); line-height: 1.6; }
    .card-corner {
      position: absolute;
      top: 0; right: 0;
      width: 18px; height: 18px;
      border-bottom: 18px solid var(--rouge);
      border-left: 18px solid transparent;
    }

    /* COMPÉTENCES */
    #competences { background: var(--noir); }
    .skills-list { display: flex; flex-direction: column; gap: 1.2rem; max-width: 600px; }
    .skill-item { display: flex; flex-direction: column; gap: 0.4rem; }
    .skill-header {
      display: flex;
      justify-content: space-between;
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.8rem;
      letter-spacing: 2px;
      color: var(--metal);
    }
    .skill-pct { color: var(--rouge-vif); }
    .skill-bar { height: 4px; background: var(--gris); }
    .skill-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--rouge), var(--rouge-vif));
      box-shadow: 0 0 8px var(--rouge-vif);
      animation: grow 1.4s ease-out forwards;
      transform-origin: left;
      transform: scaleX(0);
    }
    @keyframes grow { to { transform: scaleX(1); } }

    /* CONTACT */
    #contact { background: var(--noir-2); border-top: 1px solid var(--gris); }
    .contact-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
    .contact-info p { color: var(--gris-clair); line-height: 1.8; margin-bottom: 2rem; }
    .contact-links { display: flex; flex-direction: column; gap: 0.8rem; }
    .contact-link {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      color: var(--gris-clair);
      text-decoration: none;
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.85rem;
      transition: color 0.2s;
    }
    .contact-link:hover { color: var(--rouge-vif); }
    .contact-link span {
      width: 6px; height: 6px;
      background: var(--rouge);
      display: inline-block;
      transform: rotate(45deg);
      flex-shrink: 0;
    }
    .contact-form { display: flex; flex-direction: column; gap: 1rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
    .form-group label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--rouge-vif);
    }
    .form-group input,
    .form-group textarea {
      background: var(--noir-3);
      border: 1px solid var(--gris);
      color: var(--blanc);
      font-family: 'Rajdhani', sans-serif;
      font-size: 1rem;
      padding: 0.75rem 1rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      resize: none;
    }
    .form-group input:focus,
    .form-group textarea:focus {
      border-color: var(--rouge);
      box-shadow: 0 0 12px var(--rouge-glow);
    }

    /* FOOTER */
    footer {
      position: relative;
      z-index: 2;
      background: var(--noir);
      border-top: 1px solid var(--rouge);
      padding: 1.5rem 8rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    footer p {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.72rem;
      color: var(--gris-clair);
      letter-spacing: 2px;
    }
    footer .rog-logo {
      font-family: 'Orbitron', monospace;
      font-size: 0.8rem;
      color: var(--rouge-vif);
      letter-spacing: 4px;
      text-shadow: 0 0 8px var(--rouge-vif);
    }

    /* SCANLINES */
    .scanlines {
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        to bottom,
        transparent, transparent 2px,
        rgba(0,0,0,0.04) 2px, rgba(0,0,0,0.04) 4px
      );
      pointer-events: none;
      z-index: 999;
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      section, nav, footer { padding-left: 2rem; padding-right: 2rem; }
      #hero { padding: 6rem 2rem 4rem; }
      .stats-bar { grid-template-columns: 1fr 1fr; }
      .contact-inner { grid-template-columns: 1fr; }
      .hero-deco { display: none; }
      #hero::after { display: none; }
    }
  </style>
</head>
<body>

